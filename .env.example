# Speechify API key injected upstream by every shim. Leave empty to run in
# pass-through mode (supported by the streaming-family providers).
SPEECHIFY_API_KEY=

# Address the shim listens on.
SHIM_ADDR=:8080

# Speechify API base URL (no trailing slash).
SPEECHIFY_BASE_URL=https://api.speechify.ai

# Optional: pin the upstream Speechify API contract version.
SPEECHIFY_VERSION=

# Default Speechify model when a request does not select one.
SHIM_DEFAULT_MODEL=simba-english

# Per-request upstream timeout (Go duration, e.g. 30s, 1m).
SHIM_REQUEST_TIMEOUT=30s
